---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import SearchFilter from '../components/SearchFilter.astro';

const recipes = await getCollection('recipes');
const sorted = recipes.sort((a, b) => {
  const da = a.data.date ? new Date(a.data.date).getTime() : 0;
  const db = b.data.date ? new Date(b.data.date).getTime() : 0;
  return db - da;
});

const cuisines = [...new Set(recipes.map(r => r.data.cuisine))].sort();
---

<BaseLayout title="Recipes">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Collection</p>
      <h1>Home Recipes</h1>
      <p class="count">{recipes.length} dishes</p>
    </div>
  </section>

  <section class="recipes">
    <div class="container">
      <SearchFilter cuisines={cuisines} />
      <div class="grid" id="grid">
        {sorted.map((r, i) => <RecipeCard recipe={r} index={i} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding: 3rem 0 4rem; }

  .eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.75rem;
    animation: fadeUp 0.4s var(--ease) both;
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    margin-bottom: 1rem;
    animation: fadeUp 0.4s var(--ease) 0.03s both;
  }

  .count {
    font-size: 1rem;
    color: var(--text-muted);
    animation: fadeUp 0.4s var(--ease) 0.06s both;
  }

  .recipes { padding-bottom: 3rem; }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1000px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .hero { padding: 2rem 0 2.5rem; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
