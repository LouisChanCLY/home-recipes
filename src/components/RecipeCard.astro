---
import type { CollectionEntry } from 'astro:content';

interface Props {
  recipe: CollectionEntry<'recipes'>;
  index?: number;
}

const { recipe, index = 0 } = Astro.props;
const { dish, cuisine, portions, calories, tags } = recipe.data;
const baseUrl = import.meta.env.BASE_URL;
---

<a
  href={`${baseUrl}recipes/${recipe.slug}/`}
  class="card"
  style={`--delay: ${index * 40}ms`}
  data-cuisine={cuisine}
  data-tags={tags.join(',')}
>
  <div class="card-top">
    <span class="cuisine">{cuisine}</span>
    {calories > 0 && <span class="kcal">{calories}</span>}
  </div>

  <h3>{dish}</h3>

  <div class="card-bottom">
    <span>{portions}p</span>
    <span class="dot"></span>
    {tags.slice(0, 2).map(t => <span class="tag">{t}</span>)}
  </div>

  <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <path d="M7 17L17 7M17 7H7M17 7V17"/>
  </svg>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    min-height: 160px;
    position: relative;
    transition: background 0.2s var(--ease), border-color 0.2s var(--ease), transform 0.2s var(--ease);
    animation: fadeUp 0.4s var(--ease) var(--delay) both;
  }

  .card:hover {
    background: var(--bg-hover);
    border-color: #333;
    transform: translateY(-2px);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cuisine {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .kcal {
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  .kcal::after {
    content: ' kcal';
  }

  h3 {
    font-size: 1.35rem;
    flex: 1;
    transition: color 0.2s var(--ease);
  }

  .card:hover h3 { color: var(--accent); }

  .card-bottom {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: auto;
  }

  .dot {
    width: 3px;
    height: 3px;
    background: var(--border);
    border-radius: 50%;
  }

  .tag { color: var(--text-dim); }

  .arrow {
    position: absolute;
    bottom: 1.25rem;
    right: 1.25rem;
    width: 18px;
    height: 18px;
    color: var(--text-dim);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: all 0.2s var(--ease);
  }

  .card:hover .arrow {
    opacity: 1;
    transform: translate(0, 0);
    color: var(--accent);
  }
</style>
